# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000

# MongoDB Connection
# Replace with your MongoDB Atlas connection string or local MongoDB URL
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/QuickHire?retryWrites=true&w=majority

# JWT Configuration
# Use a strong, random secret key in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Email Configuration (Brevo SMTP)
# Sign up at https://www.brevo.com for SMTP credentials
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_user
SMTP_PASSWORD=your_brevo_smtp_password
SENDER_EMAIL=your_verified_email@example.com
SENDER_NAME=QuickHire Team

# OTP Configuration
OTP_EXPIRY_MINUTES=10
